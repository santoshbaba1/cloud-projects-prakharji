{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOneBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::irsa-demo-bucket-<ACCOUNT_ID>",
        "arn:aws:s3:::irsa-demo-bucket-<ACCOUNT_ID>/*"
      ]
    }
  ]
}
